# Required runtime settings
TIMESCALE_HOST=timescale
TIMESCALE_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=clashking
TIMESCALE_SSLMODE=disable
ENCRYPTION_KEY=fernet_key
SECRET_KEY=jwt_access_secret
REFRESH_SECRET=jwt_refresh_secret
BOT_TOKEN=discord_bot_token
API_BOT_TOKEN=service_to_service_bot_token
PROXY_BASE_URL=http://clashking-proxy:8011

# Discord OAuth
DISCORD_CLIENT_ID=discord_application_id
DISCORD_CLIENT_SECRET=discord_oauth_secret
DISCORD_REDIRECT_URI=https://app.clashking.com/auth/callback

# Email authentication
SMTP_USERNAME=smtp_username
SMTP_PASSWORD=smtp_password
SMTP_FROM=noreply@clashk.ing
SMTP_REPLY_TO=noreply@clashk.ing
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_SSL_TLS=false

# Optional integrations
REDIS_IP=valkey
REDIS_PW=valkey_password
BUNNY_ACCESS_KEY=bunny_access_key
API_ANALYTICS_KEY=analytics_token
INTERNAL_API_TOKEN=internal_api_token
LINK_API_USER=link_api_user
LINK_API_PW=link_api_password
COC_EMAIL=clash_api_email
COC_PASSWORD=clash_api_password
SENTRY_DSN_API=https://public@example.ingest.sentry.io/project
APP_SENTRY_DSN=https://public@example.ingest.sentry.io/project
LOG_LEVEL=INFO

# Local development only
LOCAL=false
DEV_USER_ID=local_user_id
